/*
 * DarlingV2 — SuperMini nRF52840 + 2×CD74HC4067
 * Гибридная клавиатура: 28 клавиш, каждая с мех-свичем + HE-сенсором
 * Раскладка: 6 рядов в physical_layout, но матрица 6×16 для совместимости с MUX
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/he/mouse_forwarder.h>
#include <dt-bindings/he/gamepad_forwarder.h>
#include <input/he_processors.dtsi>
#include <physical_layouts.dtsi>

/* ============================================
 * ADC: 2 канала для 2 мультиплексоров
 * ============================================ */
&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@0 {
        reg = <0>;
        zephyr,input-positive = <NRF_SAADC_AIN0>;  /* P0.02 */
        zephyr,gain = "ADC_GAIN_1_2";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };

    channel@5 {
        reg = <5>;
        zephyr,input-positive = <NRF_SAADC_AIN5>;  /* P0.29 */
        zephyr,gain = "ADC_GAIN_1_2";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 10)>;
        zephyr,resolution = <12>;
    };
};

&raw_sp {
    matrix-size = <2 14>;   /* 2 MUX × 14 каналов = 28 HE */
    working-area = <250 3050>;
    filter-coefficients = <0x3ca485df 0x3d2485df 0x3ca485df 0x3f800000 0xbfc7cf71 0x3f242f9d>;
};

&he_pass {
    kscan-passthrough-position = <2700>;
    keymap-size = <12>;
};

&rt_pass {
    keymap-size = <12>;
};

&mouse_fw {
    time-to-max-speed-ms = <300>;
    working-area = <300 2800>;
    scale-x-float = <0x40400000>;
    scale-y-float = <0x40400000>;
    scale-h-wheel-float = <0x40400000>;
    scale-v-wheel-float = <0x40400000>;
};

&he_trans {
    // log;
};

/ {
    chosen {
        zmk,kscan = &kscan;
        zmk,physical-layout = &physical_layout0;
    };

    /* ============================================
     * МЕХАНИЧЕСКИЕ СВИЧИ (4×7 = 28 кнопок)
     * Используются ВСЕ 28 позиций матрицы
     * ============================================ */
    kscan_mech: kscan_mech {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
    };

    /* ============================================
     * HE через 2×CD74HC4067 (28 кнопок)
     * ============================================ */
    kscan_mux: kscan-mux {
        compatible = "he,kscan-multiplexer";
        resolution = <12>;
        wait-period-idle = <5>;
        wait-period-press = <1>;
        kscan-forwarder = <&kscan_forwarder>;
        
        default-calibration-min = <2000>;
        default-calibration-max = <3000>;
        default-deadzone-top = <250>;
        default-deadzone-bottom = <250>;

        /* MUX1: 14 каналов (0-13) */
        mux0: mux-0 {
            io-channels = <&adc 0>;
            address-range-min = <0>;
            address-range-max = <13>;
            switch-height = <3300>;
        };

        /* MUX2: 14 каналов (0-13) */
        mux1: mux-1 {
            io-channels = <&adc 5>;
            address-range-min = <0>;
            address-range-max = <13>;
            switch-height = <3300>;
        };
    };

    /* ============================================
     * Композитный сканер
     * Размеры 4×7 (для совместимости с MUX)
     *   
     * ============================================ */
    kscan: kscan0 {
        compatible = "zmk,kscan-composite";
        wakeup-source;
        rows = <4>;
        columns = <7>;

        gpio-matrix {
            kscan = <&kscan_mech>;
            row-offset = <0>;
            col-offset = <0>;
        };
        adc-direct {
            kscan = <&kscan_mux>;
            row-offset = <0>;
            col-offset = <0>;
        };
    };

    /* ============================================
     * SOCD и прочее
     * ============================================ */
    socd_d: he-socd1 {
        compatible = "he,input-processor-socd";
        #input-processor-cells = <1>;
        sensitivity = <250>;
        kscan-forwarder = <&kscan_forwarder>;
        kscan-passthrough;
        actuation-point = <2800>;
        type = "priority_deeper";
    };

    // ps: he_set_p {
    //     compatible = "he,behavior-pulse-set";
    //     #binding-cells = <1>;
    //     pulse-set-forwarder = <&pulse_set_forwarder>;
    // };

    he_transform: he_transform {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <4>;
        map = <
           RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)
             
        >;
    };

    he_keymap: he-keymap {
        compatible = "he,input-processor-keymap";
        #input-processor-cells = <1>;
        transform = <&he_transform>;
    };

    central_listener: central_listener {
        compatible = "he,input-listener";
        device = <&kscan_mux>;
        input-processors = <&raw_sp>;

        layer0 { layers = <0>; input-processors = <&he_keymap 0>; };
        layer1 { layers = <1>; input-processors = <&he_keymap 1>; };
        layer2 { layers = <2>; input-processors = <&he_keymap 2>; };
        layer3 { layers = <3>; input-processors = <&he_keymap 3>; };
    };

    /* ============================================
     * Физический layout (DarlingV2, 28 клавиш)
     * ============================================ */
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Darling2 Default";
        kscan = <&kscan>;
        transform = <&default_transform>;
        
        keys = 
            /* Row 0: Tab, Q, W, E, R, T, Y */
            <&key_physical_attrs 100 100   50  100  0  0  0>
            , <&key_physical_attrs 100 100 150  100  0  0  0>
            , <&key_physical_attrs 100 100 250  100  0  0  0>
            , <&key_physical_attrs 100 100 350  100  0  0  0>
            , <&key_physical_attrs 100 100 450  100  0  0  0>
            , <&key_physical_attrs 100 100 550  100  0  0  0>
            , <&key_physical_attrs 100 100 650  100  0  0  0>

            /* Row 1: caps, A, S, D, F, G, H */
            , <&key_physical_attrs 100 100   50  200  0  0  0>
            , <&key_physical_attrs 100 100 150  200  0  0  0>
            , <&key_physical_attrs 100 100 250  200  0  0  0>
            , <&key_physical_attrs 100 100 350  200  0  0  0>
            , <&key_physical_attrs 100 100 450  200  0  0  0>
            , <&key_physical_attrs 100 100 550  200  0  0  0>
            , <&key_physical_attrs 100 100 650  200  0  0  0>

            /* Row 2: shift, Z, X, C, V, B , N */
            , <&key_physical_attrs 100 100   50  300  0  0  0>
            , <&key_physical_attrs 100 100 150  300  0  0  0>
            , <&key_physical_attrs 100 100 250  300  0  0  0>
            , <&key_physical_attrs 100 100 350  300  0  0  0>
            , <&key_physical_attrs 100 100 450  300  0  0  0>
            , <&key_physical_attrs 100 100 550  300  0  0  0>
            , <&key_physical_attrs 100 100 650  300  0  0  0>

            /* Row 3: ctrl, alt, win, Up, Down, Space, Return */
            , <&key_physical_attrs 100 100   50  400  0  0  0>
            , <&key_physical_attrs 100 100 150  400  0  0  0>
            , <&key_physical_attrs 100 100 250  400  0  0  0>
            , <&key_physical_attrs 100 100 350  400  0  0  0>
            , <&key_physical_attrs 100 100 450  400  0  0  0>
            , <&key_physical_attrs 100 100 550  400  0  0  0>
            , <&key_physical_attrs 100 100 650  400  0  0  0>

            
            ;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)
            
        >;
    };
};
