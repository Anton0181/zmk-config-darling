/* DarlingV2 - только мех-свичи 4×7, без HE */

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan;
        zmk,physical-layout = &physical_layout0;
    };

    /* Мех-свичи 4×7 (28 кнопок) */
    kscan: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
        /* col-gpios и row-gpios в overlay */
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Darling3 Default";
        kscan = <&kscan>;
        transform = <&default_transform>;
        
        keys = 
            /* Row 0: Tab, Q, W, E, R, T, Y */
            <&key_physical_attrs 100 100   50  100  0  0  0>
            , <&key_physical_attrs 100 100 150  100  0  0  0>
            , <&key_physical_attrs 100 100 250  100  0  0  0>
            , <&key_physical_attrs 100 100 350  100  0  0  0>
            , <&key_physical_attrs 100 100 450  100  0  0  0>
            , <&key_physical_attrs 100 100 550  100  0  0  0>
            , <&key_physical_attrs 100 100 650  100  0  0  0>

            /* Row 1: caps, A, S, D, F, G, H */
            , <&key_physical_attrs 100 100   50  200  0  0  0>
            , <&key_physical_attrs 100 100 150  200  0  0  0>
            , <&key_physical_attrs 100 100 250  200  0  0  0>
            , <&key_physical_attrs 100 100 350  200  0  0  0>
            , <&key_physical_attrs 100 100 450  200  0  0  0>
            , <&key_physical_attrs 100 100 550  200  0  0  0>
            , <&key_physical_attrs 100 100 650  200  0  0  0>

            /* Row 2: shift, Z, X, C, V, B , N */
            , <&key_physical_attrs 100 100   50  300  0  0  0>
            , <&key_physical_attrs 100 100 150  300  0  0  0>
            , <&key_physical_attrs 100 100 250  300  0  0  0>
            , <&key_physical_attrs 100 100 350  300  0  0  0>
            , <&key_physical_attrs 100 100 450  300  0  0  0>
            , <&key_physical_attrs 100 100 550  300  0  0  0>
            , <&key_physical_attrs 100 100 650  300  0  0  0>

            /* Row 3: ctrl, alt, win, Up, Down, Space, Return */
            , <&key_physical_attrs 100 100   50  400  0  0  0>
            , <&key_physical_attrs 100 100 150  400  0  0  0>
            , <&key_physical_attrs 100 100 250  400  0  0  0>
            , <&key_physical_attrs 100 100 350  400  0  0  0>
            , <&key_physical_attrs 100 100 450  400  0  0  0>
            , <&key_physical_attrs 100 100 550  400  0  0  0>
            , <&key_physical_attrs 100 100 650  400  0  0  0>

            
            ;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <7>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)
        >;
    };
};
